{
  "name": "ai-festivals-api",
  "version": "1.0.0",
  "description": "Backend API for AI Festivals Scraper",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "node scripts/switch-schema.js && prisma generate && tsc",
    "start": "npx prisma db push --skip-generate && node dist/index.js",
    "railway:migrate": "node scripts/switch-schema.js && prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "db:push": "node scripts/switch-schema.js && prisma db push",
    "seed:tunisia": "ts-node prisma/tunisia-seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/dotenv": "^6.1.1",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^3.1.0",
    "helmet": "^7.1.0",
    "lru-cache": "^10.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-slow-down": "^1.3.5",
    "@types/node": "^20.10.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
