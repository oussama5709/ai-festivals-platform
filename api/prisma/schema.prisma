generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id           String    @id @default(cuid())
  title        String
  description  String?
  date         DateTime?
  endDate      DateTime?
  location     String?
  isOnline     Boolean   @default(false)
  url          String?   @unique
  source       String
  region       String
  regionArabic String?
  category     String
  qualityScore Float
  scrapedAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Competition fields
  isCompetition      Boolean   @default(false)
  prize              String?
  prizeAmount        Float?
  prizeCurrency      String?
  eligibility        String?
  howToApply         String?
  submissionDeadline DateTime?
  competitionStatus  String?   // "open" | "closed" | "upcoming"

  // CFP fields
  hasCfp             Boolean   @default(false)
  cfpDeadline        DateTime?
  cfpUrl             String?
  cfpDescription     String?

  // Tunisia specific
  isTunisia          Boolean   @default(false)

  // Festival / media classification
  festivalType       String?   // "cinema" | "photo" | "video" | "mixed-image" | "ai" | "hackathon"
  mediaType          String?   // "film" | "short-film" | "documentary" | "photo" | "video" | "all"
  governorate        String?   // "Tunis" | "Sfax" | "Sousse" | "Gabes" ...
  prizeType          String?   // "cash" | "honorary" | "both" | "internship"
  organizerType      String?   // "university" | "ministry" | "ngo" | "private" | "ieee"

  // Film competition fields
  isFilmCompetition  Boolean  @default(false)
  filmDurationMin    Int?     // minimum film duration in seconds
  filmDurationMax    Int?     // maximum film duration in seconds
  filmGenres         String[] // accepted genres
  filmFreewayUrl     String?  // direct FilmFreeway submission URL
  competitionTopics  String[] // ["AI in healthcare", "Generative AI", "AI ethics"]

  // ── Registration Intelligence ────────────────────────────────────────────
  // Free-cost / eligibility metadata discovered by registrationDiscoveryService.
  officialWebsite        String?    // organizer's canonical site (falls back to `url` if unset)
  registrationStatus     String?    // "open" | "opening_soon" | "closing_soon" | "closed" | "cancelled" | "waiting_list" | "invitation_only" | "unknown"
  registrationOpensAt    DateTime?
  registrationClosesAt   DateTime?  // generic close date; falls back to submissionDeadline/cfpDeadline if unset
  participationCost      Float?
  currency               String?
  isFree                 Boolean?
  countryRestrictions    String?
  ageRestrictions        String?
  requiredDocuments      String?
  rulesPdfUrl            String?
  contactEmail           String?
  contactPhone           String?
  organizerName          String?
  organizerWebsite       String?
  socialMedia            String?    // JSON string, e.g. {"twitter":"...","instagram":"..."}
  lastVerifiedAt         DateTime?
  registrationConfidence Float?     // 0-1 confidence score of the discovered registration data

  registrationLinks RegistrationLink[]

  @@index([region])
  @@index([category])
  @@index([date])
  @@index([qualityScore])
  @@index([isCompetition])
  @@index([hasCfp])
  @@index([isTunisia])
  @@index([registrationStatus])
}

// One event can accept submissions through multiple official platforms
// (official website + FilmFreeway + Eventbrite + Google Form, etc).
model RegistrationLink {
  id            String    @id @default(cuid())
  eventId       String
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  platform      String    // "official" | "filmfreeway" | "festhome" | "eventbrite" | "google-form" |
                          // "submittable" | "easychair" | "ex-ordo" | "openreview" | "conftool" |
                          // "microsoft-cmt" | "pretalx" | "oxford-abstracts" | "whova" | "openwater" | "other"
  url           String
  label         String?   // raw anchor text found on the page, e.g. "Apply Now"
  isPrimary     Boolean   @default(false)
  confidence    Float     @default(0) // 0-1, how sure the heuristic is this is a real official registration link

  status        String    @default("unknown") // "valid" | "broken" | "unknown"
  isActive      Boolean   @default(true)       // false once superseded by a replacement link (kept for history)
  lastCheckedAt DateTime?
  lastValidAt   DateTime?
  discoveredAt  DateTime  @default(now())

  @@unique([eventId, url])
  @@index([eventId])
  @@index([platform])
  @@index([status])
}

model ScrapeRun {
  id           String    @id @default(cuid())
  apifyRunId   String    @unique
  status       String
  eventsFound  Int       @default(0)
  regions      String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  topics    String[]
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model SecurityLog {
  id        String   @id @default(cuid())
  type      String
  ip        String
  ua        String?
  path      String?
  method    String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([type])
  @@index([createdAt])
}
