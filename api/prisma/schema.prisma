generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id           String    @id @default(cuid())
  title        String
  description  String?
  date         DateTime?
  endDate      DateTime?
  location     String?
  isOnline     Boolean   @default(false)
  url          String?   @unique
  source       String
  region       String
  regionArabic String?
  category     String
  qualityScore Float
  scrapedAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Competition fields
  isCompetition      Boolean   @default(false)
  prize              String?
  prizeAmount        Float?
  prizeCurrency      String?
  eligibility        String?
  howToApply         String?
  submissionDeadline DateTime?
  competitionStatus  String?   // "open" | "closed" | "upcoming"

  // CFP fields
  hasCfp             Boolean   @default(false)
  cfpDeadline        DateTime?
  cfpUrl             String?
  cfpDescription     String?

  // Tunisia specific
  isTunisia          Boolean   @default(false)

  // Festival / media classification
  festivalType       String?   // "cinema" | "photo" | "video" | "mixed-image" | "ai" | "hackathon"
  mediaType          String?   // "film" | "short-film" | "documentary" | "photo" | "video" | "all"
  governorate        String?   // "Tunis" | "Sfax" | "Sousse" | "Gabes" ...
  prizeType          String?   // "cash" | "honorary" | "both" | "internship"
  organizerType      String?   // "university" | "ministry" | "ngo" | "private" | "ieee"

  // Film competition fields
  isFilmCompetition  Boolean  @default(false)
  filmDurationMin    Int?     // minimum film duration in seconds
  filmDurationMax    Int?     // maximum film duration in seconds
  filmGenres         String[] // accepted genres
  filmFreewayUrl     String?  // direct FilmFreeway submission URL
  competitionTopics  String[] // ["AI in healthcare", "Generative AI", "AI ethics"]

  @@index([region])
  @@index([category])
  @@index([date])
  @@index([qualityScore])
  @@index([isCompetition])
  @@index([hasCfp])
  @@index([isTunisia])
}

model ScrapeRun {
  id           String    @id @default(cuid())
  apifyRunId   String    @unique
  status       String
  eventsFound  Int       @default(0)
  regions      String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  topics    String[]
  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model SecurityLog {
  id        String   @id @default(cuid())
  type      String
  ip        String
  ua        String?
  path      String?
  method    String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([type])
  @@index([createdAt])
}
